# Shared application settings
NODE_ENV=development

# Backend
PORT=3001
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
MONGODB_URI=mongodb://localhost:27017/wiki-manager
JWT_SECRET=change-this-in-local-env
JWT_EXPIRE=7d

# Frontend
# Use same-origin /api locally with the Vite proxy and in the unified Vercel deployment.
VITE_API_URL=/api

# Optional local override for the Vite dev proxy target.
# If omitted, the client proxy falls back to http://localhost:${PORT}
# VITE_DEV_API_PROXY_TARGET=http://localhost:3001

# AI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Cloud fallback (optional)
GEMINI_API_KEY=your-gemini-api-key
